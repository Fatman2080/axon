{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Block Height",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "cometbft_consensus_height",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      }
    },
    {
      "title": "Connected Peers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "cometbft_p2p_peers",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 0 }] } }
      }
    },
    {
      "title": "Block Time (seconds)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(cometbft_consensus_height[1m]) ",
          "legendFormat": "blocks/min"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      }
    },
    {
      "title": "Validators",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "cometbft_consensus_validators",
          "legendFormat": "active"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      }
    },
    {
      "title": "Block Height Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "cometbft_consensus_height",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Peer Count Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "cometbft_p2p_peers",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Consensus Rounds",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "cometbft_consensus_rounds",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Mempool Size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "cometbft_mempool_size",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Block Size (bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "cometbft_consensus_block_size_bytes",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Tx Throughput (per block)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "cometbft_consensus_num_txs",
          "legendFormat": "{{instance}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["axon", "blockchain", "cosmos"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Axon Testnet",
  "uid": "axon-testnet",
  "version": 1
}
